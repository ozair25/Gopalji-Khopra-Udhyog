rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == "admin@gopalji" || request.auth.token.email == "admin@gopalji.com" || request.auth.token.email == "sayedozair25@gmail.com");
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'businessName', 'phone', 'status', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.businessName is string && data.businessName.size() <= 200 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.status in ['new', 'contacted', 'completed'] &&
             data.createdAt == request.time;
    }

    match /inquiries/{inquiryId} {
      // Public can create inquiries
      allow create: if isValidInquiry(incoming());
      
      // Admin can manage everything
      allow read, update, delete: if isAdmin();
    }
  }
}
